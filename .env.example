# 复制为 .env 并填入真实值: `cp .env.example .env`
# .env 已被 .gitignore 忽略, 不会提交。run.sh 启动时自动加载。

# DeepSeek (LLM) —— 必填
DEEPSEEK_API_KEY=

# 阿里云 DashScope (ASR / TTS) —— 必填
DASHSCOPE_API_KEY=

# 高德开放平台 Web 服务 key —— 查天气工具(get_weather)用; 留空则不启用该工具。
# 申请: https://console.amap.com → 应用管理 → Key(类型选"Web服务")。
AMAP_API_KEY=

# WebSocket 共享访问令牌: 留空=不校验(本地开发)。公网部署务必设一个够长的随机串。
VCA_AUTH_TOKEN=

# 可选: DeepSeek 走代理(本机开了 Clash 等再设); 置空=直连。
# DEEPSEEK_PROXY=http://127.0.0.1:7890
